  <script>
    // 课程数据
    const lessons = {
      hardware: {
        title: '认识手机', subtitle: '了解手机的各个部件', type: 'hardware',
        steps: [
          { part: 'power', name: '电源键', description: '在手机右侧，长按可以开机或关机，短按可以锁屏或唤醒屏幕', tip: '这是电源键，很重要！' },
          { part: 'volume', name: '音量键', description: '在手机左侧，上面的键是增大音量，下面的键是减小音量', tip: '音量键可以调节声音大小' },
          { part: 'screen', name: '屏幕', description: '手机正面的大玻璃就是屏幕，用手指轻轻点击或滑动来操作', tip: '屏幕是用手触摸操作的' },
          { part: 'charging', name: '充电口', description: '在手机底部，用来连接充电器给手机充电', tip: '没电了就要在这里充电' },
          { part: 'speaker', name: '扬声器', description: '在手机底部，打电话、看视频时声音从这里出来', tip: '声音从这里出来' }
        ]
