<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>手机学习助手</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #FDF6EC;
      --fg: #2D2A26;
      --muted: #8B8680;
      --accent: #E85D3B;
      --accent-light: #FFEEE9;
      --card: #FFFFFF;
      --border: #E8E2DA;
      --success: #4A9B7F;
      --phone-bg: #1A1A1A;
    }
   
    * { font-family: 'Noto Sans SC', sans-serif; }
    body { background: var(--bg); color: var(--fg); }
   
    .warm-bg {
      background:
        radial-gradient(ellipse at 20% 20%, rgba(232, 93, 59, 0.08) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 80%, rgba(74, 155, 127, 0.06) 0%, transparent 50%),
        var(--bg);
    }
   
    .phone-frame {
      background: linear-gradient(145deg, #2a2a2a 0%, #1a1a1a 100%);
      border-radius: 40px;
      padding: 12px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(255, 255, 255, 0.1) inset;
    }
   
    .phone-screen {
      background: linear-gradient(180deg, #f5f5f5 0%, #ffffff 100%);
      border-radius: 32px;
      overflow: hidden;
      position: relative;
    }
   
    .phone-notch {
      position: absolute;
      top: 8px;
      left: 50%;
      transform: translateX(-50%);
      width: 80px;
      height: 24px;
      background: #1a1a1a;
      border-radius: 12px;
      z-index: 10;
    }
   
    .phone-exterior {
      background: linear-gradient(145deg, #3a3a3a 0%, #1a1a1a 100%);
      border-radius: 36px;
      padding: 8px;
      position: relative;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255,255,255,0.1);
    }
   
    .phone-exterior-screen {
      background: #111;
      border-radius: 28px;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
   
    .phone-button {
      position: absolute;
      background: linear-gradient(180deg, #4a4a4a 0%, #2a2a2a 100%);
      border-radius: 2px;
      cursor: pointer;
      transition: all 0.2s;
    }
   
    .phone-button:hover { background: linear-gradient(180deg, #5a5a5a 0%, #3a3a3a 100%); }
    .phone-button:active { transform: scale(0.95); }
    .phone-button.highlight { box-shadow: 0 0 0 3px var(--accent), 0 0 20px rgba(232, 93, 59, 0.5); }
   
    .power-button { width: 4px; height: 60px; right: -4px; top: 100px; }
    .volume-up { width: 4px; height: 40px; left: -4px; top: 80px; }
    .volume-down { width: 4px; height: 40px; left: -4px; top: 130px; }
   
    .annotation { position: absolute; display: flex; align-items: center; opacity: 0; transition: opacity 0.4s; }
    .annotation.visible { opacity: 1; }
    .annotation-line { width: 40px; height: 2px; background: var(--accent); position: relative; }
    .annotation-line::before { content: ''; position: absolute; width: 8px; height: 8px; background: var(--accent); border-radius: 50%; }
    .annotation-text { background: var(--accent); color: white; padding: 8px 14px; border-radius: 10px; font-weight: 700; font-size: 14px; white-space: nowrap; margin-left: 8px; }
   
    .charging-port { position: absolute; bottom: -4px; left: 50%; transform: translateX(-50%); width: 30px; height: 4px; background: #333; border-radius: 2px; }
    .speaker-holes { position: absolute; bottom: -4px; display: flex; gap: 3px; }
    .speaker-hole { width: 3px; height: 4px; background: #333; border-radius: 1px; }
   
    .app-icon {
      width: 56px; height: 56px; border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; position: relative;
    }
    .app-icon:hover { transform: scale(1.08); }
    .app-icon:active { transform: scale(0.95); }
    .app-icon.highlight { animation: pulse-highlight 1.5s ease-in-out infinite; }
   
    @keyframes pulse-highlight {
      0%, 100% { box-shadow: 0 0 0 4px rgba(232, 93, 59, 0.4); }
      50% { box-shadow: 0 0 0 12px rgba(232, 93, 59, 0); }
    }
   
    .tip-bubble {
      background: var(--accent); color: white;
      padding: 16px 20px; border-radius: 16px;
      position: relative; animation: float-in 0.4s ease-out;
      max-width: 320px;
    }
    .tip-bubble::before { content: ''; position: absolute; width: 0; height: 0; border: 12px solid transparent; }
    .tip-bubble.arrow-bottom::before { bottom: -20px; left: 50%; transform: translateX(-50%); border-top-color: var(--accent); }
   
    @keyframes float-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
   
    .step-indicator { display: flex; gap: 8px; align-items: center; }
    .step-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--border); transition: all 0.3s; }
    .step-dot.active { background: var(--accent); width: 28px; border-radius: 5px; }
    .step-dot.done { background: var(--success); }
   
    .feature-card {
      background: var(--card); border: 2px solid var(--border);
      border-radius: 20px; padding: 20px;
      cursor: pointer; transition: all 0.3s;
    }
    .feature-card:hover {
      border-color: var(--accent); transform: translateY(-4px);
      box-shadow: 0 12px 24px -8px rgba(232, 93, 59, 0.15);
    }
   
    .part-card { background: var(--card); border: 2px solid var(--border); border-radius: 16px; padding: 20px; transition: all 0.3s; }
    .part-card.active { border-color: var(--accent); background: var(--accent-light); }
   
    @media (prefers-reduced-motion: no-preference) {
      .fade-up { animation: fadeUp 0.6s ease-out backwards; }
      .fade-up:nth-child(1) { animation-delay: 0.05s; }
      .fade-up:nth-child(2) { animation-delay: 0.1s; }
      .fade-up:nth-child(3) { animation-delay: 0.15s; }
      .fade-up:nth-child(4) { animation-delay: 0.2s; }
      .fade-up:nth-child(5) { animation-delay: 0.25s; }
      .fade-up:nth-child(6) { animation-delay: 0.3s; }
      .fade-up:nth-child(7) { animation-delay: 0.35s; }
      .fade-up:nth-child(8) { animation-delay: 0.4s; }
    }
   
    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
   
    .success-check {
      width: 80px; height: 80px; border-radius: 50%; background: var(--success);
      display: flex; align-items: center; justify-content: center;
      animation: success-pop 0.5s ease-out;
    }
    @keyframes success-pop { 0% { transform: scale(0); } 50% { transform: scale(1.2); } 100% { transform: scale(1); } }
   
    .pulse-glow { animation: pulse-glow 2s ease-in-out infinite; }
    @keyframes pulse-glow { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
   
    .screen-time { font-size: 48px; font-weight: 200; color: white; letter-spacing: 2px; }
    .screen-date { font-size: 14px; color: rgba(255,255,255,0.6); margin-top: 4px; }
   
    .volume-display {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      background: rgba(0,0,0,0.8); padding: 16px 24px; border-radius: 12px; display: none;
    }
    .volume-display.show { display: flex; align-items: center; gap: 12px; }
    .volume-bars { display: flex; gap: 3px; align-items: flex-end; height: 20px; }
    .volume-bar { width: 4px; background: white; border-radius: 2px; }
   
    .settings-item { display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; border-bottom: 1px solid #eee; }
    .settings-icon { width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; margin-right: 12px; }
   
    .wifi-item { display: flex; align-items: center; padding: 12px 16px; border-bottom: 1px solid #eee; cursor: pointer; }
    .wifi-item:hover { background: #f5f5f5; }
    .wifi-item.connected { background: #f0fdf4; }
   
    .slider-track { width: 100%; height: 6px; background: #e5e5e5; border-radius: 3px; position: relative; }
    .slider-fill { height: 100%; background: var(--accent); border-radius: 3px; }
    .slider-thumb { width: 24px; height: 24px; background: white; border: 3px solid var(--accent); border-radius: 50%; position: absolute; top: 50%; transform: translate(-50%, -50%); box-shadow: 0 2px 6px rgba(0,0,0,0.15); }
   
    .video-call-screen { background: #1a1a1a; height: 100%; display: flex; flex-direction: column; }
    .video-call-main { flex: 1; display: flex; align-items: center; justify-content: center; }
    .video-call-controls { padding: 20px; display: flex; justify-content: center; gap: 20px; }
    .video-call-btn { width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
   
    .scan-frame { width: 200px; height: 200px; border: 3px solid var(--accent); border-radius: 16px; position: relative; }
    .scan-frame::before { content: ''; position: absolute; top: -3px; left: -3px; right: -3px; bottom: -3px; border: 3px solid transparent; border-top-color: white; border-radius: 16px; animation: scan-line 2s linear infinite; }
    @keyframes scan-line { from { transform: translateY(0); } to { transform: translateY(200px); } }
   
    .pay-success { background: white; border-radius: 16px; padding: 24px; text-align: center; }
   
    @media (max-width: 640px) {
      .phone-frame { border-radius: 0; padding: 0; background: transparent; box-shadow: none; }
      .phone-screen { border-radius: 0; min-height: 100vh; }
      .phone-notch { display: none; }
    }
  </style>
</head>
<body class="warm-bg min-h-screen">
 
