    function simulatePowerPress() {
      const screen = document.querySelector('.phone-exterior-screen');
      if (screen) {
        screen.style.opacity = '0';
        setTimeout(() => { screen.style.opacity = '1'; }, 500);
      }
    }

    function simulateVolumeChange(delta) {
      volumeLevel = Math.max(0, Math.min(10, volumeLevel + delta));
